  pointer-events: none;
  z-index: 99990;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.032;
  mix-blend-mode: overlay;
  background-size: 256px 256px;
}

/* ─── Responsive Touch Scrollbar ─── */
/* Thickens the tracker slightly on mobile so dragging through huge gallery sets doesn't clip */
::-webkit-scrollbar         { width: 6px; height: 6px; }
::-webkit-scrollbar-track   { background: transparent; }
::-webkit-scrollbar-thumb   { background: rgba(240,235,225,0.15); border-radius: 999px; }
::-webkit-scrollbar-thumb:hover { background: rgba(240,235,225,0.30); }

@media (max-width: 640px) {
  /* Hides webkit bars completely on smaller viewpoints if dragging blocks natively */
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
}

::selection { background: var(--ember); color: #F0EBE1; }

/* ─── Responsive Typography ─── */
h1, h2, h3, h4 {
  font-family: var(--font-serif);
  font-weight: 200;
  letter-spacing: -0.03em;
}

/* Fluid type headers to stop long editorial names from clipping mobile views */
@media (max-width: 640px) {
  h1 { font-size: 2.25rem !important; font-weight: 900 !important; tracking: -0.04em !important; }
  h2 { font-size: 1.75rem !important; }
  p { font-size: 0.85rem !important; }
}

/* ─── Gallery grid responsive ─── */
@media (max-width: 768px) {
  .grid-gallery { grid-template-columns: repeat(1, 1fr) !important; gap: 1.5rem !important; }
}
@media (min-width: 769px) and (max-width: 1100px) {
  .grid-gallery { grid-template-columns: repeat(2, 1fr) !important; }
}

/* ─── Input & Form Fields ─── */
.input {
  width: 100%;
  background: var(--surface-3);
  border: 1px solid var(--ghost);
  color: var(--bone);
  font-family: var(--font-mono);
  font-size: 1rem; /* Base 16px to prevent system zoom on focus */
  padding: 0.85rem 1.2rem; /* Enhanced touch target padding */
  border-radius: 12px; /* Smooth corners matching modern mobile dashboards */
  outline: none;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  -webkit-appearance: none; /* Strip native iOS input styles */
}
.input:focus { 
  border-color: var(--ember); 
  background: var(--surface-2);
  box-shadow: 0 0 0 1px var(--ember);
}
.input::placeholder { color: var(--text-muted); }

/* Desktop scaling adjustment downwards */
@media (min-width: 641px) {
  .input { font-size: 0.8rem; padding: 0.75rem 1rem; }
}

/* ─── Mobile Optimized Buttons ─── */
.btn-primary,
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border-radius: 14px; /* Native component curvature */
  font-family: var(--font-mono);
  font-size: 0.75rem; /* Highly visible text scale */
  font-weight: 600;
  padding: 1rem 1.5rem; /* Large touchable button surfaces */
  letter-spacing: 0.12em;
  text-transform: uppercase;
  width: 100%; /* Force stacking blocks on mobile flows */
  transition: all .2s cubic-bezier(0.16, 1, 0.3, 1);
}

@media (min-width: 641px) {
  .btn-primary, .btn-ghost { width: auto; font-size: 0.68rem; letter-spacing: 0.18em; border-radius: 2px; }
}

.btn-primary {
  background: var(--bone);
  color: var(--void);
  border: 1px solid var(--bone);
}
.btn-primary:active, .btn-primary:hover {
  background: var(--ember);
  color: var(--bone);
  border-color: var(--ember);
}
.btn-ghost {
  border: 1px solid var(--ghost);
  background: rgba(255, 255, 255, 0.01);
  color: rgba(240, 235, 225, 0.6);
}
.btn-ghost:active, .btn-ghost:hover {
  border-color: var(--ghost-2);
  color: var(--bone);
  background: var(--surface-2);
}

/* ─── Animations ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(15px); }
  to   { opacity: 1; transform: translateY(0); }
}
.animate-fade-up { animation: fadeUp 0.5s cubic-bezier(0.16,1,0.3,1) both; }

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.97); }
  to   { opacity: 1; transform: scale(1); }
}
.animate-scale-in { animation: scaleIn 0.35s cubic-bezier(0.16,1,0.3,1) both; }

/* ─── Tailwind Core Framework Layers ─── */
@layer utilities {
  .responsive-form-row {
    @apply flex flex-col gap-4 sm:flex-row sm:items-center;
  }

  .gallery-input {
    @apply w-full bg-zinc-900/60 border border-white/10 text-zinc-100 rounded-2xl px-4 py-4
           text-base sm:text-sm outline-none transition-all duration-200 backdrop-blur-md
           focus:border-red-500/40 focus:ring-1 focus:ring-red-500/40 placeholder:text-zinc-600;
  }

  .mobile-file-picker {
    @apply flex flex-col items-center justify-center w-full border-2 border-dashed border-white/10 
           rounded-3xl p-6 text-center cursor-pointer bg-white/[0.01] hover:bg-white/[0.03] transition-all;
  }
}

/* ─── Strict Viewport Layout Overrides ─── */
@media (max-width: 640px) {
  /* Intercept layout compression zooming across webkit devices */
  input, select, textarea, .dynamic-text-fix {
    font-size: 16px !important; 
  }

  /* Style standard browser file-picker attachments neatly on mobile cards */
  input[type="file"]::file-selector-button {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    border-radius: 0.75rem;
    background-color: var(--surface-3);
    color: var(--bone);
    border: 1px solid var(--ghost);
    margin-right: 0.75rem;
    font-family: var(--font-mono);
  }

  select.dynamic-text-fix {
    background-position: right 1.25rem center;
    padding-right: 3rem;
  }
}


.grid-gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  min-height: 100vh;
}

img {
  image-orientation: from-image;
}

.webgl-image-container img {
  image-orientation: from-image !important;
}
footer {
  /* This prevents the footer from ever being covered by transformed elements */
  clear: both;
  width: 100%;
  position: relative;
  z-index: 10;
}

/* Forces browsers to respect EXIF orientation data */
img, 
canvas {
  image-orientation: from-image;
 transform: rotate(180deg); 
 
}
